# Backend Service Config
CABLEWAY_HOST=0.0.0.0
CABLEWAY_PORT=3001

# NATS JetStream
CABLEWAY_NATS_URL=nats://127.0.0.1:4222

# ClickHouse
CABLEWAY_CLICKHOUSE_URL=http://default:@127.0.0.1:8123

# Feature flags
