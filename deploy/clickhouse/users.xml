<?xml version="1.0"?>
<clickhouse>
    <users>
        <default>
            <password></password>
            <networks>
                <ip>::/0</ip>
            </networks>
            <profile>default</profile>
            <quota>default</quota>
            <access_management>1</access_management>
        </default>
        <cableway_app>
            <password_sha256_hex>change_me_to_sha256_hash_in_production</password_sha256_hex>
            <networks>
                <ip>172.28.0.0/24</ip>
            </networks>
            <profile>default</profile>
            <quota>app</quota>
            <access_management>0</access_management>
        </cableway_app>
        <cableway_read>
            <password_sha256_hex>change_me_also</password_sha256_hex>
            <networks>
                <ip>172.28.0.0/24</ip>
            </networks>
            <profile>readonly</profile>
            <quota>default</quota>
            <access_management>0</access_management>
            <allow_databases>
                <database>cableway_monitor</database>
            </allow_databases>
        </cableway_read>
    </users>

    <profiles>
        <default>
            <max_memory_usage>2000000000</max_memory_usage>
            <load_balancing>random</load_balancing>
            <allow_experimental_analyzer>1</allow_experimental_analyzer>
            <log_queries>1</log_queries>
            <query_profiler_real_time_period_ns>0</query_profiler_real_time_period_ns>
        </default>
        <readonly>
            <readonly>1</readonly>
            <max_memory_usage>1000000000</max_memory_usage>
        </readonly>
    </profiles>

    <quotas>
        <default>
            <interval>
                <duration>3600</duration>
                <queries>0</queries>
                <errors>0</errors>
                <result_rows>0</result_rows>
                <read_rows>0</read_rows>
                <execution_time>0</execution_time>
            </interval>
        </default>
        <app>
            <interval>
                <duration>3600</duration>
                <queries>0</queries>
                <execution_time>0</execution_time>
                <read_rows>0</read_rows>
            </interval>
        </app>
    </quotas>
</clickhouse>
